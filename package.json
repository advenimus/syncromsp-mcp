{
  "name": "@advenimus/syncromsp-mcp",
  "version": "0.1.0",
  "description": "MCP server for SyncroMSP — full API coverage for tickets, customers, assets, invoices, and 30+ resource types",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "syncromsp-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "manifest.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build",
    "validate:mcpb": "mcpb validate manifest.json"
  },
  "keywords": [
    "mcp",
    "syncro",
    "syncromsp",
    "msp",
    "rmm",
    "psa",
    "it-management",
    "model-context-protocol"
  ],
  "author": "Advenimus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/advenimus/syncromsp-mcp.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
