# === Required: Syncro API Credentials ===
SYNCRO_API_KEY=your-api-key-here
SYNCRO_SUBDOMAIN=your-subdomain-here

# === Transport (stdio or http) ===
MCP_TRANSPORT=stdio
MCP_PORT=8080

# === Docker OAuth2 Proxy Settings ===
# Only needed when deploying via docker-compose with OAuth2 proxy

# OAuth2 provider: google, github, azure, oidc, etc.
# OAUTH2_PROVIDER=google

# OAuth2 client credentials (from your provider's developer console)
# OAUTH2_CLIENT_ID=your-client-id
# OAUTH2_CLIENT_SECRET=your-client-secret

# Cookie encryption secret (generate with: python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())')
# OAUTH2_COOKIE_SECRET=your-cookie-secret

# Allowed email domains (* for all, or comma-separated list)
# OAUTH2_EMAIL_DOMAINS=yourcompany.com

# Port the OAuth2 proxy listens on
# PROXY_PORT=8443
