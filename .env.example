# === Required: Syncro API Credentials ===
SYNCRO_API_KEY=your-api-key-here
SYNCRO_SUBDOMAIN=your-subdomain-here

# === Transport (stdio or http) ===
MCP_TRANSPORT=stdio
MCP_PORT=8080

# === HTTP/Docker Deployment ===
# The public URL where this server is reachable (required for OAuth)
# Must be HTTPS for production (e.g., https://mcp.yourcompany.com)
# MCP_BASE_URL=https://mcp.yourcompany.com

# OAuth authentication (enabled by default in HTTP mode)
# Set to "false" to disable (not recommended for public deployments)
# MCP_AUTH=true
